# Copy to .env.local (gitignored) and fill in real values.
# Used by `next dev` for local development.

# Postgres connection string Hyperdrive proxies in production — the local
# dev server connects to the same real database via this. Ask a teammate
# for the value, or find it in the Cloudflare dashboard under
# Workers & Pages > Hyperdrive > (this project's config).
# See db/README.md for the schema this connects to.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=
