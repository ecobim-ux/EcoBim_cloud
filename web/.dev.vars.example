# Copy to .dev.vars (gitignored) and fill in real values.
# Used by Wrangler / opennextjs-cloudflare for `npm run preview` and the
# Cloudflare Workers local runtime — separate from .env.local, which only
# `next dev` reads. Same Hyperdrive connection string as .env.local.

NEXTJS_ENV=development
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=
